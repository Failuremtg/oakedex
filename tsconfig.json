{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "types": ["jest"],
    "paths": {
      "@/*": [
        "./*"
      ],
      "react-native-draggable-flatlist": [
        "./node_modules/react-native-draggable-flatlist/lib/typescript/index.d.ts"
      ],
      "react-native-draggable-flatlist/*": [
        "./node_modules/react-native-draggable-flatlist/lib/typescript/*"
      ]
    }
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "constants/**/*.ts",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "web-build",
    "landing",
    "shopify-shelly-webhook",
    "scripts"
  ]
}
